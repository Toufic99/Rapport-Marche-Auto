# 🔐 Configuration d'Exemple
# COPIER en .env et modifier les valeurs si nécessaire

# =====================================
# CONFIGURATION SCRAPING
# =====================================

# Timeout par requête (secondes)
REQUEST_TIMEOUT=10

# Nombre de tentatives en cas d'erreur
MAX_RETRIES=3

# Délai par défaut entre requêtes (secondes)
# Sera override par délai aléatoire (1-5s)
DELAY_BETWEEN_REQUESTS=2

# Nombre d'erreurs consécutives avant arrêt
MAX_CONSECUTIVE_ERRORS=5

# =====================================
# CONFIGURATION BASE DE DONNÉES
# =====================================

# Chemin vers la base de données SQLite
DB_PATH=./leboncoin_vehicles.db

# Créer backup avant chaque scraping
BACKUP_DB=True

# =====================================
# CONFIGURATION IMAGES
# =====================================

# Télécharger les photos des véhicules
DOWNLOAD_IMAGES=True

# Qualité des images (low, medium, high)
IMAGE_QUALITY=medium

# Nombre maximum d'images par véhicule
MAX_IMAGES_PER_VEHICLE=10

# =====================================
# CONFIGURATION LOGGING
# =====================================

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Fichier de log
LOG_FILE=./scraper.log

# Garder logs précédents
KEEP_LOGS=True

# =====================================
# CONFIGURATION RAPPORT
# =====================================

# Générer rapport HTML
GENERATE_HTML=True

# Générer export CSV
GENERATE_CSV=True

# Générer statistiques JSON
GENERATE_STATS=True

# =====================================
# OPTIONS AVANCÉES
# =====================================

# Mode debug (affiche plus de détails)
DEBUG_MODE=False

# Vérifier certificat SSL
VERIFY_SSL=True

# User-Agent personnalisé (optionnel)
# Laisser vide pour rotation automatique
CUSTOM_USER_AGENT=

# Proxy (optionnel, format: http://IP:PORT)
# PROXY=http://proxy.example.com:8080

# =====================================
# NOTES
# =====================================
# - Laisser les valeurs par défaut pour démarrage simple
# - Augmenter DELAY_BETWEEN_REQUESTS si bloqué (403)
# - Réduire DELAY_BETWEEN_REQUESTS pour plus de speed
# - Ne pas modifier DB_PATH sauf si vraiment nécessaire
